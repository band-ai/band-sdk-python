# QA Test Harness — Environment Variables
# Copy to .env and fill in real values:  cp .env.example .env

# Platform (prod by default; switch to localhost for local dev)
THENVOI_REST_URL=https://app.band.ai
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# Localhost alternative:
# THENVOI_REST_URL=http://localhost:4000
# THENVOI_WS_URL=ws://localhost:4000/api/v1/socket/websocket

# Human API key — used by the harness to create rooms, send messages, observe
THENVOI_API_KEY_USER=

# LLM keys — set whichever adapters you plan to test
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google: use EITHER an API key OR gcloud ADC (Vertex AI)
GOOGLE_API_KEY=
# If using gcloud instead of API key, uncomment these:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# (setup_agents.py auto-detects gcloud and sets these for you)

# Letta (if testing letta adapter)
LETTA_BASE_URL=https://api.letta.com
LETTA_API_KEY=
MCP_SERVER_URL=http://localhost:8002/sse
