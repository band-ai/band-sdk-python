# Test environment configuration
# Copy this file to .env.test and fill in your credentials
#
# To run integration tests:
#   uv run pytest tests/integration/ -v -s
#
# To run only unit tests (no credentials needed):
#   uv run pytest tests/ --ignore=tests/integration/

# Server URLs (defaults to local development)
BAND_BASE_URL=http://localhost:4000
BAND_WS_URL=ws://localhost:4000/api/v1/socket/websocket

# Primary test agent (for agent API tests)
# Create a remote agent in the Band platform and paste its API key here
BAND_API_KEY=<your-agent-api-key>
TEST_AGENT_ID=<agent-uuid>

# Secondary test agent (for multi-agent tests)
# Optional: only needed for tests that require two agents communicating
BAND_API_KEY_2=<your-second-agent-api-key>
TEST_AGENT_ID_2=<second-agent-uuid>

# User API key (owner of the above agents)
# Used for dynamic agent creation/deletion in enhanced integration tests
# Get this from your user profile in the Band platform
BAND_API_KEY_USER=<your-user-api-key>

# =============================================================================
# E2E Test Configuration
# =============================================================================
# E2E tests run real adapters with real LLMs against a real platform.
# They are opt-in and never run in CI.
#
# To run E2E tests:
#   E2E_TESTS_ENABLED=true uv run pytest tests/e2e/ -v -s --no-cov

# Set to true to enable E2E tests (default: false)
# E2E_TESTS_ENABLED=false

# LLM models for E2E tests (cheap models to minimize cost)
# E2E_LLM_MODEL=gpt-5.4-mini
# Use a modern Anthropic model — the baseline judge uses structured outputs,
# which the older claude-3-haiku-20240307 does not support.
# E2E_ANTHROPIC_MODEL=claude-haiku-4-5

# Timeout in seconds for waiting for agent responses
# E2E_TIMEOUT=30

# --- Baseline E2E toolkit (tests/e2e/baseline) ---
# Needs only BAND_API_KEY_USER (above) — it provisions its own agents and runs
# them with generated per-agent keys, so a static BAND_API_KEY is not required.
#
# Judge model (defaults to E2E_ANTHROPIC_MODEL). Must support structured outputs.
# E2E_JUDGE_MODEL=claude-haiku-4-5
#
# Provisioning / cleanup policy:
# BAND_E2E_AUTOCLEAN=true              # reap provisioned agents+rooms on teardown
# BAND_E2E_ORPHAN_SWEEP=true           # sweep leftover agents from crashed runs at startup
# BAND_E2E_ORPHAN_MAX_AGE_MINUTES=120  # only sweep agents older than this
