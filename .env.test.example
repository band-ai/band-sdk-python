# Test environment configuration
# Copy this file to .env.test and fill in your credentials
#
# To run integration tests:
#   uv run pytest tests/integration/ -v -s
#
# To run only unit tests (no credentials needed):
#   uv run pytest tests/ --ignore=tests/integration/

# Server URLs (defaults to local development)
THENVOI_BASE_URL=http://localhost:4000
THENVOI_WS_URL=ws://localhost:4000/api/v1/socket/websocket

# Primary test agent (for agent API tests)
# Create a remote agent in the Thenvoi platform and paste its API key here
THENVOI_API_KEY=<your-agent-api-key>
TEST_AGENT_ID=<agent-uuid>

# Secondary test agent (for multi-agent tests)
# Optional: only needed for tests that require two agents communicating
THENVOI_API_KEY_2=<your-second-agent-api-key>
TEST_AGENT_ID_2=<second-agent-uuid>

# User API key (owner of the above agents)
# Used for dynamic agent creation/deletion in enhanced integration tests
# Get this from your user profile in the Thenvoi platform
THENVOI_API_KEY_USER=<your-user-api-key>

# =============================================================================
# E2E Test Configuration
# =============================================================================
# E2E tests run real adapters with real LLMs against a real platform.
# They are opt-in and never run in CI.
#
# To run E2E tests:
#   E2E_TESTS_ENABLED=true uv run pytest tests/e2e/ -v -s --no-cov

# Set to true to enable E2E tests (default: false)
# E2E_TESTS_ENABLED=false

# LLM models for E2E tests (cheap models to minimize cost)
# E2E_LLM_MODEL=gpt-5.4-mini
# E2E_ANTHROPIC_MODEL=claude-sonnet-4-6

# Timeout in seconds for waiting for agent responses
# E2E_TIMEOUT=30

# Baseline live Tier-2 gates (all default off / fail-closed)
# E2E_BASELINE_L0_LIVE=true
# E2E_BASELINE_L1_LIVE=true
# E2E_BASELINE_L2_LIVE=true
# E2E_BASELINE_L3_LIVE=true
# E2E_BASELINE_L4_LIVE=true
# LANGGRAPH_RESTART_SMOKE=true

# Baseline live Tier-2 artifact output and explicit pricing inputs.
# Prices are intentionally supplied by the runner so tests do not bake stale
# provider pricing into the repo. Required whenever a baseline live gate is on.
# E2E_BASELINE_ARTIFACT_DIR=.claude/reports/e2e-baseline-artifacts
# E2E_BASELINE_RUN_ID=20260610T000000Z
# E2E_BASELINE_INPUT_USD_PER_MILLION_TOKENS=<positive-input-usd-per-million-tokens>
# E2E_BASELINE_OUTPUT_USD_PER_MILLION_TOKENS=<positive-output-usd-per-million-tokens>
# E2E_BASELINE_PRICING_SOURCE=<current-provider-pricing-source>

# L0/L4 Echo simulated participant. Use a real registered remote agent running
# the deterministic Echo adapter from the baseline scenario.
# E2E_ECHO_AGENT_ID=<uuid>
# E2E_ECHO_AGENT_API_KEY=<agent-api-key>
# E2E_ECHO_AGENT_NAME=Echo
# E2E_ECHO_AGENT_HANDLE=<owner>/echo

# L3 live proof uses three existing remote agents; descriptions on those agents
# should identify calculator vs greeting-card specialist because routing must be
# driven by participant context, not a hardcoded coordinator prompt.
# E2E_L3_TEST_AGENT_ID=<uuid>
# E2E_L3_TEST_AGENT_API_KEY=<agent-api-key>
# E2E_L3_TEST_AGENT_NAME=<name>
# E2E_L3_TEST_AGENT_HANDLE=<owner>/agent-one
# E2E_L3_TEST_AGENT_DESCRIPTION=Routes requests using participant descriptions and relays final answers.
# E2E_L3_CALC_AGENT_ID=<uuid>
# E2E_L3_CALC_AGENT_API_KEY=<agent-api-key>
# E2E_L3_CALC_AGENT_NAME=Agent Two
# E2E_L3_CALC_AGENT_HANDLE=<owner>/agent-two
# E2E_L3_CALC_AGENT_DESCRIPTION=Performs exact arithmetic and returns only computed results.
# E2E_L3_GREETER_AGENT_ID=<uuid>
# E2E_L3_GREETER_AGENT_API_KEY=<agent-api-key>
# E2E_L3_GREETER_AGENT_NAME=Agent Three
# E2E_L3_GREETER_AGENT_HANDLE=<owner>/agent-three
# E2E_L3_GREETER_AGENT_DESCRIPTION=Crafts personalized greetings and greeting-card copy.
